<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="SEC Analysis Data Flow" id="sec-flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=none;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="250" y="30" width="900" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="title" value="&lt;font color=&quot;#ffffff&quot; style=&quot;font-size:20px&quot;&gt;&lt;b&gt;SEC ANALYSIS — Data Flow Diagram&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#aaaaaa&quot; style=&quot;font-size:11px&quot;&gt;Specific Energy Consumption = Total Energy x POE% / Production&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="350" y="33" width="700" height="50" as="geometry"/>
        </mxCell>

        <!-- ============ STEP 1: USER INPUT ============ -->
        <mxCell id="s1_label" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#4472C4&quot;&gt;&lt;b&gt;STEP 1 — USER INPUT&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="105" width="250" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="year_start" value="&lt;b&gt;Start Year&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888&quot; style=&quot;font-size:9px&quot;&gt;e.g. 2024&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4472C4;fontColor=#ffffff;strokeColor=#2F5496;shadow=1;arcSize=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="year_end" value="&lt;b&gt;End Year&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888&quot; style=&quot;font-size:9px&quot;&gt;e.g. 2026&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4472C4;fontColor=#ffffff;strokeColor=#2F5496;shadow=1;arcSize=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="220" y="140" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="poe" value="&lt;b&gt;POE (%)&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888&quot; style=&quot;font-size:9px&quot;&gt;% of Energy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4472C4;fontColor=#ffffff;strokeColor=#2F5496;shadow=1;arcSize=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="140" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="matrix" value="&lt;b&gt;Matrix Type&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#888&quot; style=&quot;font-size:9px&quot;&gt;Monthly / Quarterly&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4472C4;fontColor=#ffffff;strokeColor=#2F5496;shadow=1;arcSize=12;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="140" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- ============ STEP 2: AJAX REQUEST ============ -->
        <mxCell id="s2_label" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#ED7D31&quot;&gt;&lt;b&gt;STEP 2 — AJAX REQUEST&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="250" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="fetch" value="&lt;b&gt;POST /sec-analysis/data&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;{start_year, end_year, poe, matrix_type}&lt;/font&gt;" style="shape=mxgraph.flowchart.document;whiteSpace=wrap;html=1;fillColor=#FCE4CC;strokeColor=#ED7D31;shadow=1;fontSize=11;arcSize=8;size=0.1;" vertex="1" parent="1">
          <mxGeometry x="60" y="250" width="350" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="e_y1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2F5496;strokeWidth=1.5;rounded=1;" edge="1" source="year_start" target="fetch" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_y2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2F5496;strokeWidth=1.5;rounded=1;" edge="1" source="year_end" target="fetch" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_p1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2F5496;strokeWidth=1.5;rounded=1;" edge="1" source="poe" target="fetch" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_m1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2F5496;strokeWidth=1.5;rounded=1;" edge="1" source="matrix" target="fetch" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============ STEP 3: DATABASE QUERIES ============ -->
        <mxCell id="s3_label" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#C00000&quot;&gt;&lt;b&gt;STEP 3 — DATABASE QUERIES (Server-Side)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="400" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="db1" value="&lt;b&gt;energy_data_usages&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;JOIN energy_data&lt;br&gt;WHERE month BETWEEN start-01 AND end-12&lt;br&gt;GROUP BY energy_data_id, month&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#C00000;fontColor=#ffffff;strokeColor=#8B0000;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="375" width="350" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="db2" value="&lt;b&gt;energy_resource_usages&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;JOIN energy_resource_data&lt;br&gt;WHERE month BETWEEN start-01 AND end-12&lt;br&gt;GROUP BY energy_resource_data_id, month&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#C00000;fontColor=#ffffff;strokeColor=#8B0000;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="375" width="350" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="db3" value="&lt;b&gt;monthly_productions&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;WHERE month BETWEEN start-01 AND end-12&lt;br&gt;GROUP BY product_name, month&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#548235;fontColor=#ffffff;strokeColor=#375623;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="375" width="350" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="e_f1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C00000;strokeWidth=1.5;rounded=1;" edge="1" source="fetch" target="db1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_f2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C00000;strokeWidth=1.5;rounded=1;" edge="1" source="fetch" target="db2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_f3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#548235;strokeWidth=1.5;rounded=1;" edge="1" source="fetch" target="db3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- JSON Response -->
        <mxCell id="json" value="&lt;b&gt;JSON Response to Client&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#555&quot;&gt;{ energy: {sourceId: {month: gj}}, resource: {sourceId: {month: gj}},&lt;br&gt;production: {product: {month: qty}}, energySources: [...], resourceSources: [...] }&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=#DEE2E6;shadow=1;arcSize=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="510" width="600" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_j1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#999;strokeWidth=1.5;rounded=1;" edge="1" source="db1" target="json" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_j2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#999;strokeWidth=1.5;rounded=1;" edge="1" source="db2" target="json" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_j3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#999;strokeWidth=1.5;rounded=1;" edge="1" source="db3" target="json" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============ STEP 4: CLIENT CALCULATION ============ -->
        <mxCell id="s4_label" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#548235&quot;&gt;&lt;b&gt;STEP 4 — CLIENT-SIDE CALCULATION (JavaScript)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="600" width="450" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="calc1" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;1&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;Sum energy sources per month&lt;br&gt;&lt;font color=&quot;#548235&quot;&gt;&lt;b&gt;totalEnergy = Σ (energy source GJ)&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#A9D18E;shadow=1;arcSize=8;fontSize=11;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="60" y="635" width="280" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="calc2" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;2&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;Sum resource sources per month&lt;br&gt;&lt;font color=&quot;#548235&quot;&gt;&lt;b&gt;totalResource = Σ (resource source GJ)&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#A9D18E;shadow=1;arcSize=8;fontSize=11;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="380" y="635" width="280" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="calc3" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;3&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;Combine all energy&lt;br&gt;&lt;font color=&quot;#548235&quot;&gt;&lt;b&gt;totalCombined = totalEnergy + totalResource&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#A9D18E;shadow=1;arcSize=8;fontSize=11;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="700" y="635" width="310" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="calc4" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;4&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;Apply POE percentage&lt;br&gt;&lt;font color=&quot;#C55A11&quot;&gt;&lt;b&gt;adjustedEnergy = totalCombined × (POE / 100)&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4CC;strokeColor=#F4B183;shadow=1;arcSize=8;fontSize=11;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="180" y="720" width="340" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="calc5" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;5&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;Calculate SEC&lt;br&gt;&lt;font color=&quot;#C00000&quot; style=&quot;font-size:13px&quot;&gt;&lt;b&gt;SEC = adjustedEnergy / productionQty&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;arcSize=8;fontSize=11;align=left;spacingLeft=15;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="580" y="720" width="350" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="e_c1" style="strokeColor=#A9D18E;strokeWidth=1.5;rounded=1;" edge="1" source="json" target="calc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_c2" style="strokeColor=#A9D18E;strokeWidth=1.5;rounded=1;" edge="1" source="json" target="calc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_c3" style="strokeColor=#A9D18E;strokeWidth=1.5;rounded=1;" edge="1" source="calc1" target="calc3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_c3b" style="strokeColor=#A9D18E;strokeWidth=1.5;rounded=1;" edge="1" source="calc2" target="calc3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_c4" style="strokeColor=#C55A11;strokeWidth=1.5;rounded=1;" edge="1" source="calc3" target="calc4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_c5" style="strokeColor=#D6B656;strokeWidth=2;rounded=1;" edge="1" source="calc4" target="calc5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============ STEP 5: FILTER EFFECT ============ -->
        <mxCell id="s5_label" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#7030A0&quot;&gt;&lt;b&gt;FILTER EFFECT — Data Sources Tab&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="810" width="350" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="filter_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAF0;strokeColor=#C5A3D9;arcSize=6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="840" width="540" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="f1" value="When user filters energy types via Data Sources tab:" style="text;html=1;fontSize=11;align=left;fontStyle=1;fontColor=#7030A0;" vertex="1" parent="1">
          <mxGeometry x="80" y="850" width="400" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="f2" value="&lt;b&gt;filteredTotalEnergy&lt;/b&gt; = Σ (only SELECTED energy source GJ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#C5A3D9;fontSize=11;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="878" width="500" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="f3" value="&lt;b&gt;filteredTotalResource&lt;/b&gt; = Σ (only SELECTED resource source GJ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#C5A3D9;fontSize=11;align=left;spacingLeft=10;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="916" width="500" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="f4" value="&lt;b&gt;SEC recalculated from filtered totals&lt;/b&gt; — &quot;Filtered&quot; badge shown on table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C00000;fontColor=#ffffff;strokeColor=#8B0000;fontSize=11;align=left;spacingLeft=10;arcSize=6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="955" width="500" height="32" as="geometry"/>
        </mxCell>

        <!-- ============ STEP 6: OUTPUT ============ -->
        <mxCell id="s6_label" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#333&quot;&gt;&lt;b&gt;OUTPUT&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="700" y="810" width="150" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="out1" value="&lt;b&gt;SEC Matrix Table&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;Monthly breakdown by&lt;br&gt;energy source x product&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=#DEE2E6;shadow=1;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="840" width="200" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="out2" value="&lt;b&gt;SEC Total Table&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;Yearly SEC comparison&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=#DEE2E6;shadow=1;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="930" y="840" width="200" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="out3" value="&lt;b&gt;Charts&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;Bar, Line, Pie&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=#DEE2E6;shadow=1;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="925" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="out4" value="&lt;b&gt;Export&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;CSV / Excel&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=#DEE2E6;shadow=1;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="925" width="130" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="e_o1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#999;strokeWidth=1.5;rounded=1;" edge="1" source="calc5" target="out1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_o2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#999;strokeWidth=1.5;rounded=1;" edge="1" source="calc5" target="out2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>