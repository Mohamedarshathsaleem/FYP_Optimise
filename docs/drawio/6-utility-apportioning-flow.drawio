<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Utility Apportioning Data Flow" id="util-flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=none;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="30" width="1000" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="title" value="&lt;font color=&quot;#ffffff&quot; style=&quot;font-size:20px&quot;&gt;&lt;b&gt;UTILITY APPORTIONING — Data Flow Diagram&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#aaaaaa&quot; style=&quot;font-size:11px&quot;&gt;Energy vs Energy Resource Consumption Split (100% Auto-Generated)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="33" width="800" height="50" as="geometry"/>
        </mxCell>

        <!-- Note badge -->
        <mxCell id="note_badge" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;No user-entered data — 100% auto-generated from database&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#548235;fontColor=#ffffff;strokeColor=#375623;shadow=1;arcSize=20;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="100" width="540" height="28" as="geometry"/>
        </mxCell>

        <!-- ============ STEP 1: USER INPUT ============ -->
        <mxCell id="s1_label" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#4472C4&quot;&gt;&lt;b&gt;STEP 1 — USER INPUT&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="250" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="year" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;Select Year&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#ccc&quot;&gt;Page reload with ?year=XXXX&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4472C4;fontColor=#ffffff;strokeColor=#2F5496;shadow=1;arcSize=12;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="140" width="250" height="55" as="geometry"/>
        </mxCell>

        <!-- ============ STEP 2: SERVER QUERIES ============ -->
        <mxCell id="s2_label" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#C00000&quot;&gt;&lt;b&gt;STEP 2 — SERVER-SIDE QUERIES (UtilityApportioningController)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="225" width="550" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="q1" value="&lt;b&gt;Query 1: Energy Data&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;EnergyDataUsage&lt;br&gt;→ WHERE month LIKE '$year-%'&lt;br&gt;→ SUM(usage_gj) as total_gj&lt;br&gt;→ SUM(cost) as total_cost&lt;br&gt;→ GROUP BY month&lt;br&gt;→ keyBy('month')&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#C00000;fontColor=#ffffff;strokeColor=#8B0000;shadow=1;fontSize=11;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="60" y="265" width="330" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="q2" value="&lt;b&gt;Query 2: Resource Data&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;EnergyResourceUsage&lt;br&gt;→ WHERE month LIKE '$year-%'&lt;br&gt;→ SUM(usage_gj) as total_gj&lt;br&gt;→ SUM(cost) as total_cost&lt;br&gt;→ GROUP BY month&lt;br&gt;→ keyBy('month')&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#C00000;fontColor=#ffffff;strokeColor=#8B0000;shadow=1;fontSize=11;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="460" y="265" width="330" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2F5496;strokeWidth=2;rounded=1;" edge="1" source="year" target="q1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#2F5496;strokeWidth=2;rounded=1;" edge="1" source="year" target="q2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============ STEP 3: BUILD MATRIX ============ -->
        <mxCell id="s3_label" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#548235&quot;&gt;&lt;b&gt;STEP 3 — BUILD 12-MONTH MATRIX (Server-Side PHP)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="450" width="500" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="build" value="&lt;b&gt;Loop months 01 → 12&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;key = &quot;$year-$m&quot; → lookup energyData[key] and resourceData[key]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#A9D18E;shadow=1;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="485" width="500" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="row" value="&lt;b&gt;Per month row:&lt;/b&gt;&amp;nbsp;&amp;nbsp;energy_gj&amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;resource_gj&amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;energy_cost (RM)&amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;resource_cost (RM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#A9D18E;shadow=1;arcSize=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="550" width="550" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="e3" style="strokeColor=#A9D18E;strokeWidth=1.5;rounded=1;" edge="1" source="q1" target="build" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="strokeColor=#A9D18E;strokeWidth=1.5;rounded=1;" edge="1" source="q2" target="build" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="strokeColor=#A9D18E;strokeWidth=1.5;rounded=1;" edge="1" source="build" target="row" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============ STEP 4: CALCULATIONS ============ -->
        <mxCell id="s4_label" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#ED7D31&quot;&gt;&lt;b&gt;STEP 4 — CALCULATIONS&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="615" width="300" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="calc1" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;TOTALS&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;totalEnergyGj = Σ (all months energy GJ)&lt;br&gt;totalResourceGj = Σ (all months resource GJ)&lt;br&gt;totalEnergyCost = Σ (all months energy cost)&lt;br&gt;totalResourceCost = Σ (all months resource cost)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4CC;strokeColor=#F4B183;shadow=1;arcSize=8;fontSize=11;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="60" y="650" width="330" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="calc2" value="&lt;font style=&quot;font-size:12px&quot;&gt;&lt;b&gt;AVERAGES&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;avgEnergyGj = totalEnergyGj / 12&lt;br&gt;avgResourceGj = totalResourceGj / 12&lt;br&gt;(same formula for costs)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4CC;strokeColor=#F4B183;shadow=1;arcSize=8;fontSize=11;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="440" y="650" width="300" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="calc3" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;APPORTIONING PERCENTAGES&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;totalGj = totalEnergyGj + totalResourceGj&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;font color=&quot;#C00000&quot; style=&quot;font-size:12px&quot;&gt;&lt;b&gt;pctEnergyGj = totalEnergyGj / totalGj × 100&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#C00000&quot; style=&quot;font-size:12px&quot;&gt;&lt;b&gt;pctResourceGj = totalResourceGj / totalGj × 100&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;Same formula applied to costs using totalCost denominator&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;shadow=1;arcSize=8;fontSize=11;align=left;spacingLeft=15;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="775" width="500" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="e6" style="strokeColor=#F4B183;strokeWidth=1.5;rounded=1;" edge="1" source="row" target="calc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" style="strokeColor=#F4B183;strokeWidth=1.5;rounded=1;" edge="1" source="calc1" target="calc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" style="strokeColor=#D6B656;strokeWidth=2;rounded=1;" edge="1" source="calc1" target="calc3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============ STEP 5: OUTPUT ============ -->
        <mxCell id="s5_label" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#333&quot;&gt;&lt;b&gt;STEP 5 — OUTPUT (Two View Modes)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="680" y="615" width="350" height="25" as="geometry"/>
        </mxCell>

        <!-- Table View -->
        <mxCell id="tv_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#9DC3E6;arcSize=6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="650" width="510" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="tv_icon" value="&lt;font style=&quot;font-size:20px&quot;&gt;📊&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="690" y="655" width="40" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="tv_title" value="&lt;font style=&quot;font-size:14px&quot; color=&quot;#2F5496&quot;&gt;&lt;b&gt;Table View&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="730" y="658" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="tv1" value="&lt;b&gt;4 Summary Cards&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;Energy GJ | Resource GJ | Energy Cost | Resource Cost&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9DC3E6;fontSize=11;align=left;spacingLeft=10;arcSize=4;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="690" width="470" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="tv2" value="&lt;b&gt;Main Table:&lt;/b&gt; 12 monthly rows + Average row + Apportioning % row&lt;br&gt;&lt;font style=&quot;font-size:10px&quot; color=&quot;#666&quot;&gt;Headers: Monthly Usage (GJ) | Monthly Cost (RM)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9DC3E6;fontSize=11;align=left;spacingLeft=10;arcSize=4;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="733" width="470" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="tv3" value="&lt;b&gt;Export:&lt;/b&gt; CSV + Excel download" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9DC3E6;fontSize=11;align=left;spacingLeft=10;arcSize=4;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="775" width="470" height="25" as="geometry"/>
        </mxCell>

        <!-- Graph View -->
        <mxCell id="gv_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAF0;strokeColor=#C5A3D9;arcSize=6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="830" width="510" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="gv_icon" value="&lt;font style=&quot;font-size:20px&quot;&gt;📈&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="690" y="835" width="40" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="gv_title" value="&lt;font style=&quot;font-size:14px&quot; color=&quot;#7030A0&quot;&gt;&lt;b&gt;Graph View&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="730" y="838" width="200" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="gv1" value="&lt;b&gt;4 Summary Cards&lt;/b&gt; (same as Table View)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#C5A3D9;fontSize=11;align=left;spacingLeft=10;arcSize=4;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="870" width="470" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="gv2" value="&lt;b&gt;Chart 1:&lt;/b&gt; GJ Doughnut" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#C5A3D9;fontSize=11;align=center;arcSize=6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="903" width="150" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="gv3" value="&lt;b&gt;Chart 2:&lt;/b&gt; Cost Doughnut" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#C5A3D9;fontSize=11;align=center;arcSize=6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="903" width="150" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="gv4" value="&lt;b&gt;Chart 3:&lt;/b&gt; Monthly Bar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#C5A3D9;fontSize=11;align=center;arcSize=6;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="903" width="150" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9DC3E6;strokeWidth=1.5;rounded=1;" edge="1" source="calc3" target="tv_bg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#C5A3D9;strokeWidth=1.5;rounded=1;" edge="1" source="calc3" target="gv_bg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>