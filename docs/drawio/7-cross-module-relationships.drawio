          <mxGeometry x="1190" y="395" width="230" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="util_reads" value="&lt;b&gt;Reads from:&lt;/b&gt;&lt;br&gt;• energy_data_usages (GJ + cost)&lt;br&gt;• energy_resource_usages (GJ + cost)&lt;br&gt;• No production/variable data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#C5A3D9;fontSize=11;align=left;spacingLeft=10;arcSize=4;" vertex="1" parent="1">
