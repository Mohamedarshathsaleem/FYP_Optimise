        <!-- ============ CONNECTION ARROWS ============ -->
        <!-- energy_data_usages → SEC, EIP, Utility -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=3;strokeColor=#C00000;rounded=1;" edge="1" source="edu" target="sec_bg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
