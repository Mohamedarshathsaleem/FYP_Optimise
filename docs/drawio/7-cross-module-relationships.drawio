        <mxCell id="sec_reads" value="&lt;b&gt;Reads from:&lt;/b&gt;&lt;br&gt;• energy_data_usages (GJ)&lt;br&gt;• energy_resource_usages (GJ)&lt;br&gt;• monthly_productions (qty)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#A9D18E;fontSize=11;align=left;spacingLeft=10;arcSize=4;" vertex="1" parent="1">
