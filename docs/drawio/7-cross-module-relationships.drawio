        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=3;strokeColor=#C00000;rounded=1;" edge="1" source="edu" target="util_bg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- energy_resource_usages → SEC, EIP, Load, Utility -->
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#C00000;dashed=1;dashPattern=8 4;rounded=1;" edge="1" source="eru" target="sec_bg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#C00000;dashed=1;dashPattern=8 4;rounded=1;" edge="1" source="eru" target="eip_bg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#C00000;dashed=1;dashPattern=8 4;rounded=1;" edge="1" source="eru" target="load_bg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#C00000;dashed=1;dashPattern=8 4;rounded=1;" edge="1" source="eru" target="util_bg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- monthly_productions → SEC -->
        <mxCell id="a8" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=3;strokeColor=#548235;rounded=1;" edge="1" source="mp" target="sec_bg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- monthly_variables → EIP -->
        <mxCell id="a9" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=3;strokeColor=#548235;rounded=1;" edge="1" source="mv" target="eip_bg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- load_apportioning → Load -->
        <mxCell id="a10" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=3;strokeColor=#ED7D31;rounded=1;" edge="1" source="la_db" target="load_bg" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ============ KEY INSIGHTS ============ -->
        <mxCell id="ki_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=#DEE2E6;arcSize=4;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="1520" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="ki_title_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=none;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="580" y="730" width="440" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ki_title" value="&lt;font color=&quot;#ffffff&quot; style=&quot;font-size:13px&quot;&gt;&lt;b&gt;KEY INSIGHTS&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="680" y="732" width="240" height="26" as="geometry"/>
        </mxCell>

        <mxCell id="ki1" value="&lt;font color=&quot;#C00000&quot;&gt;&lt;b&gt;1.&lt;/b&gt;&lt;/font&gt;  &lt;b&gt;energy_data_usages&lt;/b&gt; is the most shared table — used by SEC, EIP, and Utility" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E57373;fontSize=11;align=left;spacingLeft=15;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="775" width="700" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ki2" value="&lt;font color=&quot;#C00000&quot;&gt;&lt;b&gt;2.&lt;/b&gt;&lt;/font&gt;  &lt;b&gt;energy_resource_usages&lt;/b&gt; is shared across &lt;b&gt;ALL 4 modules&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E57373;fontSize=11;align=left;spacingLeft=15;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="815" width="700" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ki3" value="&lt;font color=&quot;#C55A11&quot;&gt;&lt;b&gt;3.&lt;/b&gt;&lt;/font&gt;  &lt;b&gt;Load Apportioning is mostly standalone&lt;/b&gt; — main data is user-entered, not from other modules" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4CC;strokeColor=#F4B183;fontSize=11;align=left;spacingLeft=15;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="855" width="700" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ki4" value="&lt;font color=&quot;#2F5496&quot;&gt;&lt;b&gt;4.&lt;/b&gt;&lt;/font&gt;  &lt;b&gt;SEC and EIP read the same energy data&lt;/b&gt; but divide by different denominators" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#9DC3E6;fontSize=11;align=left;spacingLeft=15;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="810" y="775" width="700" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ki5" value="&lt;font color=&quot;#548235&quot;&gt;&lt;b&gt;5.&lt;/b&gt;&lt;/font&gt;  &lt;b&gt;No data flows between modules&lt;/b&gt; — they all read independently from source tables" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#A9D18E;fontSize=11;align=left;spacingLeft=15;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="810" y="815" width="700" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="ki6" value="&lt;font color=&quot;#7030A0&quot;&gt;&lt;b&gt;6.&lt;/b&gt;&lt;/font&gt;  &lt;b&gt;Utility Apportioning&lt;/b&gt; is the only module using server-side calculation (no AJAX)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8DAF0;strokeColor=#C5A3D9;fontSize=11;align=left;spacingLeft=15;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="810" y="855" width="700" height="30" as="geometry"/>
