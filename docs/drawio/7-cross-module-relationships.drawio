        </mxCell>
        <mxCell id="sec_formula" value="&lt;b&gt;Formula:&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#C00000&quot; style=&quot;font-size:12px&quot;&gt;&lt;b&gt;SEC = (E × POE%) / Production&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;align=left;spacingLeft=10;arcSize=4;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="510" width="280" height="45" as="geometry"/>
